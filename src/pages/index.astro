---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("journal"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

function formatDate(date: Date): string {
  return date.toLocaleDateString("pl-PL", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<BaseLayout>
  <!-- HERO -->
  <header class="relative z-10 pt-20 pb-16 text-center max-w-4xl mx-auto px-4">
    <div
      class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-800/50 border border-slate-700 text-xs font-mono text-ml mb-6"
    >
      <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
      System status: Learning...
    </div>

    <h1
      class="text-4xl md:text-6xl font-bold text-white mb-6 tracking-tight leading-tight"
    >
      Łączymy <span class="text-bim">Dane Budynkowe</span><br />
       z <span class="text-ml">Uczeniem Maszynowym</span>
    </h1>

    <p
      class="text-lg text-slate-400 mb-10 max-w-2xl mx-auto leading-relaxed"
    >
      Projekt R&D typu Open Source. Od surowych plików IFC, przez algorytmy
      Scikit-Learn, aż po automatyzację analiz energetycznych.
    </p>

    <div
      class="flex flex-wrap justify-center gap-4 md:gap-8 mb-12 font-mono text-xs md:text-sm text-slate-500"
    >
      <div class="flex items-center gap-2">
        <span class="text-bim font-bold">[IFC/Revit]</span><span>---&gt;</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-white font-bold">[Python]</span><span>---&gt;</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-ml font-bold">[ML Models]</span><span>---&gt;</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-green-400 font-bold">[Optimization]</span>
      </div>
    </div>
  </header>

  <!-- LATEST POSTS -->
  <main class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-white">
        Ostatnie <span class="text-ml">wpisy</span>
      </h2>
      <a
        href="/journal/"
        class="text-sm font-mono text-slate-500 hover:text-ml transition-colors"
      >
        Wszystkie wpisy &rarr;
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        posts.map((post) => (
          <a
            href={`/journal/${post.id}/`}
            class="group bg-card border border-slate-800 rounded-lg overflow-hidden hover:border-bim/50 transition-all flex flex-col h-full"
          >
            <div class="h-32 bg-slate-900 p-4 font-mono text-xs text-slate-500 border-b border-slate-800 flex items-center justify-center">
              <span class="text-ml text-lg">{`// ${post.id}`}</span>
            </div>
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex flex-wrap gap-2 mb-3">
                {post.data.tags.map((tag) => (
                  <span class="text-[10px] font-mono text-bim bg-bim/10 px-2 py-1 rounded uppercase">
                    {tag}
                  </span>
                ))}
              </div>
              <h3 class="text-lg font-bold text-white mb-2 group-hover:text-bim transition-colors">
                {post.data.title}
              </h3>
              <p class="text-slate-400 text-sm mb-4 flex-grow">
                {post.data.description}
              </p>
              <time
                datetime={post.data.date.toISOString()}
                class="text-xs font-mono text-slate-600"
              >
                {formatDate(post.data.date)}
              </time>
            </div>
          </a>
        ))
      }
    </div>

    {
      posts.length === 0 && (
        <p class="text-slate-500 font-mono text-center py-20">
          Brak wpisów. Dodaj plik .md do{" "}
          <code class="text-bim">src/content/journal/</code>
        </p>
      )
    }
  </main>
</BaseLayout>
