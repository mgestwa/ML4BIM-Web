---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { useTranslations } from "../../i18n/ui";
import { siteConfig } from "../../site.config";
import BimMlGraphic from "../../components/BimMlGraphic.astro";

const lang = "en";
const t = useTranslations(lang);

const posts = (await getCollection("journal"))
  .filter((p) => !p.data.draft && p.id.startsWith("en/"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-GB", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<BaseLayout title={t("site.title")} description={t("site.description")} lang={lang}>
  <header class="pt-20 pb-16 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7 flex flex-col items-start">
        <div
          class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-800/50 border border-slate-700 text-xs font-mono text-ml mb-6"
        >
          <span
            class="w-2 h-2 rounded-full bg-green-500 animate-pulse motion-reduce:animate-none"
          ></span>
          {t("hero.badge")}
        </div>

        <h1
          class="text-4xl md:text-6xl font-bold text-white mb-4 tracking-tight leading-tight"
        >
          <span class="text-ml">{t("hero.heading.line1")}</span><br />
          {t("hero.heading.line2")}
        </h1>

        <p class="text-lg md:text-xl text-slate-400 mb-10 max-w-2xl leading-relaxed">
          {t("hero.subtitle")}
        </p>

        <div class="flex flex-wrap gap-3 mb-12">
          <a
            href="/en/journal/"
            class="inline-flex items-center px-5 py-2.5 rounded-md bg-ml text-dark font-mono text-sm font-bold hover:bg-cyan-400 transition-colors"
          >
            {t("hero.cta.journal")}
          </a>
          <a
            href={siteConfig.githubUrl}
            class="inline-flex items-center px-5 py-2.5 rounded-md border border-slate-600 text-white font-mono text-sm hover:border-ml/50 hover:text-ml transition-colors"
            target="_blank"
            rel="noopener noreferrer"
          >
            {t("hero.cta.github")}
          </a>
        </div>

        <ol
          class="flex flex-col sm:flex-row sm:items-center flex-wrap gap-4 font-mono text-xs md:text-sm text-slate-400"
          aria-label={t("hero.pipeline.label")}
        >
          <li class="flex items-center gap-3">
            <div class="flex items-center gap-2 px-3 py-2 bg-slate-900/40 border border-slate-800 rounded-md shadow-sm shadow-black/20 hover:border-bim/30 hover:bg-slate-900/60 transition-all duration-300">
              <span class="w-1.5 h-1.5 rounded-full bg-bim shadow-[0_0_8px_#F59E0B]"></span>
              <span class="text-bim font-bold tracking-wide uppercase">{t("hero.pipeline.step1")}</span>
            </div>
            <div class="hidden sm:flex items-center" aria-hidden="true">
              <svg class="w-8 h-4 text-slate-800 overflow-visible" fill="none" viewBox="0 0 32 16">
                <path d="M 0,8 L 32,8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                <path d="M 26,4 L 32,8 L 26,12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M 0,8 L 32,8" stroke="#F59E0B" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="6, 26" class="animate-pulse-line" />
              </svg>
            </div>
            <span class="sm:hidden text-slate-700 pl-4" aria-hidden="true">↓</span>
          </li>

          <li class="flex items-center gap-3">
            <div class="flex items-center gap-2 px-3 py-2 bg-slate-900/40 border border-slate-800 rounded-md shadow-sm shadow-black/20 hover:border-white/20 hover:bg-slate-900/60 transition-all duration-300">
              <span class="w-1.5 h-1.5 rounded-full bg-white shadow-[0_0_8px_#ffffff]"></span>
              <span class="text-white font-bold tracking-wide uppercase">{t("hero.pipeline.step2")}</span>
            </div>
            <div class="hidden sm:flex items-center" aria-hidden="true">
              <svg class="w-8 h-4 text-slate-800 overflow-visible" fill="none" viewBox="0 0 32 16">
                <path d="M 0,8 L 32,8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                <path d="M 26,4 L 32,8 L 26,12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M 0,8 L 32,8" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="6, 26" class="animate-pulse-line" style="animation-delay: -0.5s;" />
              </svg>
            </div>
            <span class="sm:hidden text-slate-700 pl-4" aria-hidden="true">↓</span>
          </li>

          <li class="flex items-center gap-3">
            <div class="flex items-center gap-2 px-3 py-2 bg-slate-900/40 border border-slate-800 rounded-md shadow-sm shadow-black/20 hover:border-ml/30 hover:bg-slate-900/60 transition-all duration-300">
              <span class="w-1.5 h-1.5 rounded-full bg-ml shadow-[0_0_8px_#06B6D4]"></span>
              <span class="text-ml font-bold tracking-wide uppercase">{t("hero.pipeline.step3")}</span>
            </div>
            <div class="hidden sm:flex items-center" aria-hidden="true">
              <svg class="w-8 h-4 text-slate-800 overflow-visible" fill="none" viewBox="0 0 32 16">
                <path d="M 0,8 L 32,8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                <path d="M 26,4 L 32,8 L 26,12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M 0,8 L 32,8" stroke="#06B6D4" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="6, 26" class="animate-pulse-line" style="animation-delay: -1s;" />
              </svg>
            </div>
            <span class="sm:hidden text-slate-700 pl-4" aria-hidden="true">↓</span>
          </li>

          <li class="flex items-center">
            <div class="flex items-center gap-2 px-3 py-2 bg-slate-900/40 border border-slate-800 rounded-md shadow-sm shadow-black/20 hover:border-green-400/30 hover:bg-slate-900/60 transition-all duration-300">
              <span class="w-1.5 h-1.5 rounded-full bg-green-400 shadow-[0_0_8px_#34d399]"></span>
              <span class="text-green-400 font-bold tracking-wide uppercase">{t("hero.pipeline.step4")}</span>
            </div>
          </li>
        </ol>
      </div>
      <div class="lg:col-span-5 flex justify-center lg:justify-end w-full">
        <BimMlGraphic />
      </div>
    </div>
  </header>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 reveal">
    <div class="relative bg-slate-900/40 border border-slate-800/80 rounded-2xl p-8 md:p-12 overflow-hidden group hover:border-ml/20 transition-all duration-300">
      <div class="absolute inset-0 opacity-[0.02] bg-[radial-gradient(#06b6d4_1px,transparent_1px)] [background-size:16px_16px] group-hover:opacity-[0.04] transition-opacity duration-300"></div>
      <div class="absolute top-0 right-0 w-32 h-32 bg-ml/5 rounded-full blur-2xl group-hover:bg-ml/10 transition-all duration-500"></div>
      <div class="absolute bottom-0 left-0 w-32 h-32 bg-bim/5 rounded-full blur-2xl group-hover:bg-bim/10 transition-all duration-500"></div>
      
      <div class="relative z-10 flex flex-col items-center text-center max-w-3xl mx-auto">
        <span class="text-ml/20 text-6xl font-serif leading-none select-none mb-4 font-bold">“</span>
        <blockquote class="text-xl md:text-2xl font-medium text-slate-200 leading-relaxed mb-6 italic">
          {t("quote.text")}
        </blockquote>
        <div class="flex items-center gap-3">
          <span class="h-px w-6 bg-slate-700"></span>
          <cite class="text-sm font-mono text-ml uppercase tracking-wider not-italic font-bold">
            {t("quote.author")}
          </cite>
          <span class="h-px w-6 bg-slate-700"></span>
        </div>
      </div>
    </div>
  </section>

  <section
    class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 reveal"
    aria-labelledby="latest-heading"
  >
    <div class="flex items-center justify-between mb-8">
      <h2 id="latest-heading" class="text-2xl font-bold text-white">
        {t("posts.heading")} <span class="text-ml">{t("posts.heading.accent")}</span>
      </h2>
      <a
        href="/en/journal/"
        class="text-sm font-mono text-slate-500 hover:text-ml transition-colors"
      >
        {t("posts.all")} &rarr;
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        posts.map((post, idx) => {
          const slug = post.id.replace(/^en\//, "");
          const delayClass = idx === 0 ? "reveal-delay-100" : idx === 1 ? "reveal-delay-200" : "reveal-delay-300";
          return (
            <a
              href={`/en/journal/${slug}/`}
              class={`reveal ${delayClass} group bg-card border border-slate-800/80 rounded-lg overflow-hidden hover:border-ml/40 hover:-translate-y-1 hover:shadow-[0_10px_30px_-15px_rgba(6,182,212,0.15)] hover:shadow-ml/10 transition-all duration-300 flex flex-col h-full`}
            >
              <div class="aspect-video bg-slate-950 border-b border-slate-800/80 relative overflow-hidden shrink-0">
                {
                  post.data.thumbnail ? (
                    <img
                      src={post.data.thumbnail}
                      alt={post.data.title}
                      class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <div class="h-full p-4 font-mono text-xs text-slate-500 flex items-center justify-center">
                      <div class="absolute inset-0 opacity-[0.03] bg-[radial-gradient(#06b6d4_1px,transparent_1px)] [background-size:16px_16px] group-hover:opacity-[0.06] transition-opacity duration-300"></div>
                      <div class="absolute -bottom-12 -left-12 w-24 h-24 bg-ml/10 rounded-full blur-xl group-hover:bg-ml/20 transition-all duration-500"></div>
                      <span class="text-ml text-lg font-bold tracking-tight relative z-10 group-hover:scale-105 transition-all duration-300">{`// ${slug}`}</span>
                    </div>
                  )
                }
              </div>
              <div class="p-6 flex flex-col flex-grow relative">
                <div class="flex flex-wrap gap-2 mb-3">
                  {post.data.tags.map((tag) => (
                    <span class="text-[10px] font-mono text-bim bg-bim/10 px-2 py-1 rounded uppercase tracking-wider font-semibold">
                      {tag}
                    </span>
                  ))}
                </div>
                <h3 class="text-lg font-bold text-white mb-2 group-hover:text-ml transition-colors duration-300">
                  {post.data.title}
                </h3>
                <p class="text-slate-400 text-sm mb-4 flex-grow line-clamp-3 leading-relaxed">
                  {post.data.description}
                </p>
                <time
                  datetime={post.data.date.toISOString()}
                  class="text-xs font-mono text-slate-500"
                >
                  {formatDate(post.data.date)}
                </time>
              </div>
            </a>
          );
        })
      }
    </div>

    {
      posts.length === 0 && (
        <p class="text-slate-500 font-mono py-20">
          {t("posts.empty")}
        </p>
      )
    }
  </section>

  <section
    id="o-projekcie"
    class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 scroll-mt-20 reveal"
    aria-labelledby="about-heading"
  >
    <h2 id="about-heading" class="text-2xl font-bold text-white mb-4">
      {t("about.heading.prefix")} <span class="text-bim">{t("about.heading.accent")}</span>
    </h2>
    <p class="text-slate-400 leading-relaxed max-w-3xl">
      {t("about.text")}
    </p>
  </section>
</BaseLayout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(15px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes pulse-line-move {
    0% {
      stroke-dashoffset: 32;
    }
    100% {
      stroke-dashoffset: 0;
    }
  }

  .animate-pulse-line {
    animation: pulse-line-move 1.5s linear infinite;
  }

  /* Reveal scroll animations */
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal-active {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-delay-100 { transition-delay: 100ms; }
  .reveal-delay-200 { transition-delay: 200ms; }
  .reveal-delay-300 { transition-delay: 300ms; }

  @media (prefers-reduced-motion: reduce) {
    .animate-pulse-line,
    .animate-fade-in-up {
      animation: none !important;
      stroke-dasharray: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
    .reveal {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  // Simple IntersectionObserver for Scroll-Reveal animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('reveal-active');
        observer.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0.05,
    rootMargin: '0px 0px -50px 0px'
  });

  document.querySelectorAll('.reveal').forEach((el) => {
    observer.observe(el);
  });
</script>
