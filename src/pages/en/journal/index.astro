---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { useTranslations } from "../../../i18n/ui";

const lang = "en";
const t = useTranslations(lang);

const posts = (await getCollection("journal"))
  .filter((p) => !p.data.draft && p.id.startsWith("en/"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-GB", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout
  title={`${t("nav.journal")} | ML4BIM`}
  description={t("journal.description")}
  lang={lang}
>
  <header class="pt-16 pb-8 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h1
      class="text-3xl md:text-5xl font-bold text-white mb-4 tracking-tight"
    >
      {t("journal.title")} <span class="text-ml">{t("journal.title.accent")}</span>
    </h1>
    <p class="text-slate-400 text-lg max-w-2xl">
      {t("journal.description")}
    </p>
  </header>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16" aria-label="Posts list">
    <div class="space-y-6 max-w-3xl">
      {
        posts.map((post) => {
          const slug = post.id.replace(/^en\//, "");
          return (
            <a
              href={`/en/journal/${slug}/`}
              class="block group bg-card border border-slate-800 rounded-lg p-6 hover:border-ml/50 transition-all"
            >
              <div class="flex flex-wrap items-center gap-3 mb-3">
                <time
                  datetime={post.data.date.toISOString()}
                  class="text-xs font-mono text-slate-500"
                >
                  {formatDate(post.data.date)}
                </time>
                {post.data.tags.map((tag) => (
                  <span class="text-[10px] font-mono text-bim bg-bim/10 px-2 py-0.5 rounded uppercase">
                    {tag}
                  </span>
                ))}
              </div>
              <h2 class="text-xl font-bold text-white mb-2 group-hover:text-ml transition-colors">
                {post.data.title}
              </h2>
              <p class="text-slate-400 text-sm">{post.data.description}</p>
            </a>
          );
        })
      }
    </div>

    {
      posts.length === 0 && (
        <p class="text-slate-500 font-mono py-20">
          {t("posts.empty")}
        </p>
      )
    }
  </section>
</BaseLayout>
