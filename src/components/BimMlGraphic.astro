---
// BimMlGraphic.astro - Interactive Isometric SVG graphic representing BIM/MEP elements merged with Machine Learning
---

<div class="relative w-full max-w-[500px] mx-auto aspect-square select-none pointer-events-none md:pointer-events-auto group">
  <!-- Glowing background blobs for depth -->
  <div class="absolute inset-0 bg-gradient-to-tr from-ml/10 via-transparent to-bim/10 rounded-full blur-3xl -z-10 animate-pulse duration-10000"></div>
  <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-ml/20 rounded-full blur-2xl -z-10 animate-float"></div>
  <div class="absolute bottom-1/4 right-1/4 w-32 h-32 bg-bim/15 rounded-full blur-2xl -z-10 animate-float" style="animation-delay: -3s;"></div>

  <!-- Main Isometric SVG -->
  <svg
    viewBox="0 0 500 500"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full h-full drop-shadow-[0_0_30px_rgba(6,182,212,0.15)] transition-transform duration-500 hover:scale-[1.02] hover:rotate-1"
    aria-hidden="true"
  >
    <!-- DEFINITIONS: Gradients, Filters, Markers -->
    <defs>
      <!-- Glow Filters -->
      <filter id="glow-cyan" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="4" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
      <filter id="glow-orange" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="4" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>

      <!-- Gradients -->
      <linearGradient id="grad-scan" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#06B6D4" stop-opacity="0.3" />
        <stop offset="50%" stop-color="#06B6D4" stop-opacity="0.05" />
        <stop offset="100%" stop-color="#F59E0B" stop-opacity="0.2" />
      </linearGradient>
      
      <linearGradient id="grad-column" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#1e293b" stop-opacity="0.8" />
        <stop offset="100%" stop-color="#0f172a" stop-opacity="0.3" />
      </linearGradient>

      <linearGradient id="grad-pipe-cyan" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#06B6D4" />
        <stop offset="100%" stop-color="#3b82f6" />
      </linearGradient>

      <linearGradient id="grad-pipe-orange" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#F59E0B" />
        <stop offset="100%" stop-color="#ef4444" />
      </linearGradient>
    </defs>

    <!-- 1. ISOMETRIC FLOOR GRID (BIM environment representation) -->
    <g class="opacity-30">
      <!-- Outer boundary of floor -->
      <polygon points="250,360 110,290 250,220 390,290" stroke="#334155" stroke-width="1.5" />
      
      <!-- Grid lines - from Left-Back to Right-Front -->
      <line x1="145,272.5" y1="145,272.5" x2="285,342.5" y2="342.5" stroke="#1e293b" stroke-width="1" />
      <line x1="180,255" y1="180,255" x2="320,325" y2="325" stroke="#1e293b" stroke-width="1" />
      <line x1="215,237.5" y1="215,237.5" x2="355,307.5" y2="307.5" stroke="#1e293b" stroke-width="1" />
      
      <!-- Grid lines - from Right-Back to Left-Front -->
      <line x1="355,272.5" y1="355,272.5" x2="215,342.5" y2="342.5" stroke="#1e293b" stroke-width="1" />
      <line x1="320,255" y1="320,255" x2="180,325" y2="325" stroke="#1e293b" stroke-width="1" />
      <line x1="285,237.5" y1="285,237.5" x2="145,307.5" y2="307.5" stroke="#1e293b" stroke-width="1" />
    </g>

    <!-- 2. MAIN 3D STRUCTURE WIREFRAME (BIM Space) -->
    <!-- Pillars rising from the floor -->
    <line x1="110" y1="290" x2="110" y2="130" stroke="#1e293b" stroke-width="1.5" stroke-dasharray="4,4" />
    <line x1="390" y1="290" x2="390" y2="130" stroke="#1e293b" stroke-width="1.5" stroke-dasharray="4,4" />
    <line x1="250" y1="220" x2="250" y2="60" stroke="#0f172a" stroke-width="1" stroke-dasharray="2,2" />
    <!-- Front pillar - solid and highlighted -->
    <line x1="250" y1="360" x2="250" y2="200" stroke="#334155" stroke-width="1.5" />

    <!-- Ceiling plane wireframe -->
    <polygon points="250,200 110,130 250,60 390,130" stroke="#334155" stroke-width="1.5" stroke-dasharray="5,5" class="opacity-50" />

    <!-- 3. MEP EQUIPMENTS (Isometric 3D Blocks) -->
    <!-- Block A: Back Left "Chiller/AHU" -->
    <g class="transition-opacity duration-300 hover:opacity-100">
      <!-- Left face -->
      <polygon points="130,270 160,285 160,255 130,240" fill="url(#grad-column)" stroke="#334155" stroke-width="1" />
      <!-- Right face -->
      <polygon points="160,285 190,270 190,240 160,255" fill="url(#grad-column)" stroke="#475569" stroke-width="1" />
      <!-- Top face -->
      <polygon points="130,240 160,255 190,240 160,225" fill="#1e293b" stroke="#334155" stroke-width="1" />
      <!-- Small details/connections on equipment -->
      <line x1="145" y1="242.5" x2="145" y2="247.5" stroke="#06B6D4" stroke-width="1.5" />
      <line x1="155" y1="247.5" x2="155" y2="252.5" stroke="#F59E0B" stroke-width="1.5" />
    </g>

    <!-- Block B: Front Right "Server Rack / Data Controller" -->
    <g>
      <!-- Left face -->
      <polygon points="310,310 340,325 340,290 310,275" fill="url(#grad-column)" stroke="#334155" stroke-width="1" />
      <!-- Right face -->
      <polygon points="340,325 370,310 370,275 340,290" fill="url(#grad-column)" stroke="#475569" stroke-width="1" />
      <!-- Top face -->
      <polygon points="310,275 340,290 370,275 340,260" fill="#1e293b" stroke="#334155" stroke-width="1" />
      <!-- Matrix of tiny green LED dots on the server face -->
      <circle cx="348" cy="298" r="1" fill="#10B981" />
      <circle cx="354" cy="295" r="1" fill="#10B981" />
      <circle cx="360" cy="292" r="1" fill="#10B981" class="animate-ping" style="transform-origin: 360px 292px; animation-duration: 2s;" />
      <circle cx="348" cy="304" r="1" fill="#10B981" />
      <circle cx="354" cy="301" r="1" fill="#ef4444" class="animate-pulse" />
      <circle cx="360" cy="298" r="1" fill="#10B981" />
    </g>

    <!-- 4. ANIMATED PIPELINES (MEP Systems) -->
    <!-- Cyan pipeline: Cooling/Air loop with moving pulses -->
    <g>
      <!-- Secondary glowing under-pipe for neon effect -->
      <path
        d="M 160,240 L 160,180 L 220,150 L 220,200 L 280,170"
        stroke="#06B6D4"
        stroke-width="6"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="opacity-20 blur-sm"
      />
      <!-- Core Pipe -->
      <path
        id="pipe-cyan"
        d="M 160,240 L 160,180 L 220,150 L 220,200 L 280,170"
        stroke="url(#grad-pipe-cyan)"
        stroke-width="3"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <!-- Glowing data pulse flowing along the pipeline -->
      <path
        d="M 160,240 L 160,180 L 220,150 L 220,200 L 280,170"
        stroke="#ffffff"
        stroke-width="3"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-dasharray="15, 120"
        class="animate-flow-cyan filter"
        style="filter: url(#glow-cyan);"
      />
    </g>

    <!-- Amber pipeline: Heating/Data stream with moving pulses -->
    <g>
      <!-- Glowing under-pipe -->
      <path
        d="M 340,275 L 340,210 L 280,240 L 280,170"
        stroke="#F59E0B"
        stroke-width="6"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="opacity-20 blur-sm"
      />
      <!-- Core Pipe -->
      <path
        id="pipe-orange"
        d="M 340,275 L 340,210 L 280,240 L 280,170"
        stroke="url(#grad-pipe-orange)"
        stroke-width="3"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <!-- Glowing warm pulse -->
      <path
        d="M 340,275 L 340,210 L 280,240 L 280,170"
        stroke="#FFE082"
        stroke-width="3"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-dasharray="20, 100"
        class="animate-flow-orange filter"
        style="filter: url(#glow-orange);"
      />
    </g>

    <!-- 5. NEURAL NETWORK NODES & SYNAPSES (Machine Learning layer) -->
    <!-- Connected synapses (thin network wires) -->
    <g class="opacity-40">
      <line x1="280" y1="170" x2="230" y2="120" stroke="#06B6D4" stroke-width="1" stroke-dasharray="3,3" />
      <line x1="280" y1="170" x2="330" y2="130" stroke="#F59E0B" stroke-width="1" stroke-dasharray="3,3" />
      <line x1="280" y1="170" x2="280" y2="100" stroke="#ffffff" stroke-width="1" stroke-dasharray="2,2" />
      
      <line x1="230" y1="120" x2="280" y2="100" stroke="#06B6D4" stroke-width="1" />
      <line x1="330" y1="130" x2="280" y2="100" stroke="#F59E0B" stroke-width="1" />
      <line x1="230" y1="120" x2="330" y2="130" stroke="#64748b" stroke-width="1" />
    </g>

    <!-- Active synapses pulses -->
    <g>
      <circle cx="255" cy="110" r="1.5" fill="#06B6D4" class="animate-synapse-1" />
      <circle cx="305" cy="115" r="1.5" fill="#F59E0B" class="animate-synapse-2" />
    </g>

    <!-- Neural Nodes (Pulsing circles) -->
    <!-- Input/Joint Node 1: Junction point (Cyan) -->
    <g class="cursor-pointer" style="transform-origin: 280px 170px;">
      <circle cx="280" cy="170" r="8" fill="#0B1120" stroke="#06B6D4" stroke-width="2.5" class="animate-pulse" />
      <circle cx="280" cy="170" r="3" fill="#06B6D4" />
      <!-- Pulsing halo -->
      <circle cx="280" cy="170" r="14" stroke="#06B6D4" stroke-width="1" class="animate-ping opacity-30" style="transform-origin: 280px 170px; animation-duration: 2.5s;" />
    </g>

    <!-- Hidden Node 2: Left High (Cyan) -->
    <g style="transform-origin: 230px 120px;">
      <circle cx="230" cy="120" r="6" fill="#0B1120" stroke="#06B6D4" stroke-width="2" class="animate-pulse" style="animation-delay: -0.7s;" />
      <circle cx="230" cy="120" r="2.5" fill="#06B6D4" />
    </g>

    <!-- Hidden Node 3: Right High (Orange) -->
    <g style="transform-origin: 330px 130px;">
      <circle cx="330" cy="130" r="6" fill="#0B1120" stroke="#F59E0B" stroke-width="2" class="animate-pulse" style="animation-delay: -1.3s;" />
      <circle cx="330" cy="130" r="2.5" fill="#F59E0B" />
    </g>

    <!-- Output Node 4: Peak Predictor (White/Cyan Glow) -->
    <g class="filter" style="transform-origin: 280px 100px; filter: url(#glow-cyan);">
      <circle cx="280" cy="100" r="7" fill="#0B1120" stroke="#ffffff" stroke-width="2" />
      <circle cx="280" cy="100" r="3" fill="#06B6D4" class="animate-pulse" />
      <circle cx="280" cy="100" r="12" stroke="#ffffff" stroke-width="0.7" stroke-dasharray="3,3" class="animate-spin" style="transform-origin: 280px 100px; animation-duration: 8s;" />
    </g>

    <!-- 6. HIGH-TECH AI/SCANNER LAYER (A laser plane scanning down) -->
    <g class="animate-scan">
      <!-- Hologram grid scan lines -->
      <polygon
        points="250,150 110,80 250,10 390,80"
        fill="url(#grad-scan)"
        stroke="#06B6D4"
        stroke-width="1.5"
        class="opacity-75"
        style="filter: drop-shadow(0 0 4px rgba(6, 182, 212, 0.4));"
      />
      <!-- Laser corner markers -->
      <circle cx="110" cy="80" r="2.5" fill="#06B6D4" />
      <circle cx="390" cy="80" r="2.5" fill="#06B6D4" />
      <circle cx="250" cy="150" r="1.5" fill="#06B6D4" />
    </g>

    <!-- 7. SCI-FI HUD LABELS & DATAPOINTS -->
    <!-- Label Left: IFC Parser status -->
    <g class="opacity-60 hover:opacity-100 transition-opacity duration-300">
      <!-- Connection line -->
      <path d="M 110,130 L 70,110 L 40,110" stroke="#334155" stroke-width="1" stroke-dasharray="2,2" />
      <!-- Background tag -->
      <rect x="10" y="98" width="55" height="15" rx="3" fill="#1e293b" fill-opacity="0.8" stroke="#475569" stroke-width="0.5" />
      <!-- Text label -->
      <text x="14" y="109" font-family="JetBrains Mono, monospace" font-size="6.5" fill="#94a3b8" font-weight="bold">IFC.parser()</text>
      <!-- Pulsing green light -->
      <circle cx="14" cy="105.5" r="0.5" fill="#10B981" class="hidden" />
    </g>

    <!-- Label Right: Prediction output -->
    <g class="opacity-60 hover:opacity-100 transition-opacity duration-300">
      <!-- Connection line -->
      <path d="M 280,100 L 330,80 L 380,80" stroke="#334155" stroke-width="1" stroke-dasharray="2,2" />
      <!-- Background tag -->
      <rect x="380" y="70" width="70" height="20" rx="3" fill="#1e293b" fill-opacity="0.8" stroke="#F59E0B" stroke-width="0.5" />
      <!-- Text labels -->
      <text x="385" y="80" font-family="JetBrains Mono, monospace" font-size="6.5" fill="#ffffff" font-weight="bold">model.predict()</text>
      <text x="385" y="87" font-family="JetBrains Mono, monospace" font-size="6" fill="#F59E0B">val_loss: 0.024</text>
    </g>

    <!-- Label Bottom: HVAC Airflow -->
    <g class="opacity-50 hover:opacity-100 transition-opacity duration-300">
      <path d="M 220,180 L 190,165 L 140,165" stroke="#334155" stroke-width="1" stroke-dasharray="2,2" />
      <rect x="85" y="155" width="55" height="15" rx="3" fill="#0B1120" fill-opacity="0.9" stroke="#06B6D4" stroke-width="0.5" />
      <text x="89" y="165" font-family="JetBrains Mono, monospace" font-size="6" fill="#06B6D4" font-weight="bold">HVAC_DUCT_v3</text>
    </g>

    <!-- Isometric Coordinate Compass -->
    <g class="opacity-20" transform="translate(410, 410)">
      <line x1="0" y1="0" x2="20" y2="10" stroke="#94a3b8" stroke-width="1.5" />
      <text x="22" y="13" font-family="JetBrains Mono, monospace" font-size="7" fill="#94a3b8">X</text>
      
      <line x1="0" y1="0" x2="-20" y2="10" stroke="#94a3b8" stroke-width="1.5" />
      <text x="-27" y="13" font-family="JetBrains Mono, monospace" font-size="7" fill="#94a3b8">Y</text>
      
      <line x1="0" y1="0" x2="0" y2="-20" stroke="#94a3b8" stroke-width="1.5" />
      <text x="-3" y="-23" font-family="JetBrains Mono, monospace" font-size="7" fill="#94a3b8">Z</text>
    </g>
  </svg>
</div>

<style>
  /* 1. Fluid Flows along Isometric pipelines */
  @keyframes flow-cyan {
    0% {
      stroke-dashoffset: 135;
    }
    100% {
      stroke-dashoffset: 0;
    }
  }

  @keyframes flow-orange {
    0% {
      stroke-dashoffset: -120;
    }
    100% {
      stroke-dashoffset: 0;
    }
  }

  .animate-flow-cyan {
    animation: flow-cyan 3.5s linear infinite;
  }

  .animate-flow-orange {
    animation: flow-orange 4s linear infinite;
  }

  /* 2. Synapse transmission signals (data packets hopping from node to node) */
  @keyframes synapse-move-1 {
    0% {
      cx: 230;
      cy: 120;
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    50% {
      cx: 280;
      cy: 100;
      opacity: 1;
    }
    60%, 100% {
      cx: 280;
      cy: 100;
      opacity: 0;
    }
  }

  @keyframes synapse-move-2 {
    0% {
      cx: 330;
      cy: 130;
      opacity: 0;
    }
    30% {
      cx: 330;
      cy: 130;
      opacity: 0;
    }
    40% {
      opacity: 1;
    }
    80% {
      cx: 280;
      cy: 100;
      opacity: 1;
    }
    90%, 100% {
      cx: 280;
      cy: 100;
      opacity: 0;
    }
  }

  .animate-synapse-1 {
    animation: synapse-move-1 3s infinite ease-out;
  }

  .animate-synapse-2 {
    animation: synapse-move-2 3s infinite ease-out;
  }

  /* 3. Glowing holographic scanner animation */
  @keyframes scan-move {
    0%, 100% {
      transform: translateY(15px);
    }
    50% {
      transform: translateY(125px);
    }
  }

  .animate-scan {
    animation: scan-move 6s ease-in-out infinite;
  }

  /* 4. Soft floating element animation for backgrounds */
  @keyframes float-soft {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-15px);
    }
  }

  .animate-float {
    animation: float-soft 6s ease-in-out infinite;
  }

  /* Reduce animation based on accessibility preferences */
  @media (prefers-reduced-motion: reduce) {
    .animate-flow-cyan,
    .animate-flow-orange,
    .animate-synapse-1,
    .animate-synapse-2,
    .animate-scan,
    .animate-float {
      animation: none !important;
      stroke-dasharray: none !important;
      opacity: 0.7 !important;
    }
    .animate-scan {
      transform: translateY(60px) !important;
    }
  }
</style>
